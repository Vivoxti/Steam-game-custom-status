<Window x:Class="SteamGameCustomStatus.UI.Dialogs.RenameDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Rename"
        Width="380"
        SizeToContent="Height"
        Background="Transparent"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        WindowStartupLocation="Manual">
    <Window.Resources>
        <SolidColorBrush x:Key="WindowBg" Color="#1E1E1E" />
        <SolidColorBrush x:Key="BorderStroke" Color="#333333" />
        <SolidColorBrush x:Key="TextPrimary" Color="#FFFFFF" />
        <SolidColorBrush x:Key="TextSecondary" Color="#999999" />
        <SolidColorBrush x:Key="BtnBg" Color="#2D2D2D" />
        <SolidColorBrush x:Key="BtnHover" Color="#383838" />
        <SolidColorBrush x:Key="BtnPressed" Color="#252525" />
        <SolidColorBrush x:Key="AccentColor" Color="#60CDFF" />
        <SolidColorBrush x:Key="AccentHover" Color="#78D6FF" />
        <SolidColorBrush x:Key="AccentPressed" Color="#4AB8E8" />
        <SolidColorBrush x:Key="InputBg" Color="#2D2D2D" />
        <SolidColorBrush x:Key="InputBgHover" Color="#333333" />
        <SolidColorBrush x:Key="InputBorder" Color="#444444" />
        <SolidColorBrush x:Key="InputBorderHover" Color="#565656" />
        <SolidColorBrush x:Key="InputBorderFocus" Color="#60CDFF" />
        <SolidColorBrush x:Key="SuggestionPopupBg" Color="#252525" />
        <SolidColorBrush x:Key="SuggestionPopupBorder" Color="#3C3C3C" />
        <SolidColorBrush x:Key="SuggestionHoverBg" Color="#2F2F2F" />
        <SolidColorBrush x:Key="SuggestionSelectedBg" Color="#173140" />
        <SolidColorBrush x:Key="SuggestionSelectedBorder" Color="#2F6880" />
        <SolidColorBrush x:Key="SuggestionGhostText" Color="#7A7A7A" />

        <DropShadowEffect x:Key="WinShadow" BlurRadius="24" ShadowDepth="0" Opacity="0.3" Color="#000000" />

        <Style x:Key="ActionBtn" TargetType="Button">
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
            <Setter Property="Background" Value="{StaticResource BtnBg}" />
            <Setter Property="FontFamily" Value="Segoe UI Variable Display, Segoe UI" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Height" Value="34" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{StaticResource BorderStroke}"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="16,0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource BtnHover}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource BtnPressed}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="AccentBtn" TargetType="Button" BasedOn="{StaticResource ActionBtn}">
            <Setter Property="Background" Value="{StaticResource AccentColor}" />
            <Setter Property="Foreground" Value="#000000" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="16,0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource AccentHover}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource AccentPressed}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="InputChrome" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource InputBg}" />
            <Setter Property="BorderBrush" Value="{StaticResource InputBorder}" />
            <Setter Property="BorderThickness" Value="1" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource InputBgHover}" />
                    <Setter Property="BorderBrush" Value="{StaticResource InputBorderHover}" />
                </Trigger>
                <Trigger Property="IsKeyboardFocusWithin" Value="True">
                    <Setter Property="Background" Value="{StaticResource InputBg}" />
                    <Setter Property="BorderBrush" Value="{StaticResource InputBorderFocus}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SuggestionListItemStyle" TargetType="ListBoxItem">
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0,0,0,4" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Padding="10,8">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource SuggestionHoverBg}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource SuggestionSelectedBg}" />
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource SuggestionSelectedBorder}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Margin="12"
            Background="{StaticResource WindowBg}"
            BorderBrush="{StaticResource BorderStroke}"
            BorderThickness="1"
            CornerRadius="8"
            Effect="{StaticResource WinShadow}"
            MouseLeftButtonDown="TitleBar_OnMouseLeftButtonDown">
        <Grid Margin="20,16,20,18">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0"
                       FontFamily="Segoe UI Variable Display, Segoe UI"
                       FontSize="15" FontWeight="SemiBold"
                       Foreground="{StaticResource TextPrimary}"
                       Text="Rename non-Steam game" />

            <TextBlock Grid.Row="1" Margin="0,6,0,0"
                       FontFamily="Segoe UI Variable Display, Segoe UI"
                       FontSize="12"
                       Foreground="{StaticResource TextSecondary}"
                       Text="Enter a new display name for Steam." />

            <Border x:Name="NameInputBorder"
                    Grid.Row="2" Margin="0,12,0,0"
                    Style="{StaticResource InputChrome}"
                    CornerRadius="6"
                    Height="40"
                    Padding="2,0"
                    VerticalAlignment="Top">
                <Grid>
                    <TextBlock x:Name="InlineSuggestionText"
                               Margin="8,0,8,0"
                               VerticalAlignment="Center"
                               FontFamily="Segoe UI Variable Text, Segoe UI"
                               FontSize="13"
                               TextOptions.TextFormattingMode="Display"
                               Visibility="Collapsed"
                               IsHitTestVisible="False">
                        <Run x:Name="InlineSuggestionPrefixRun" Foreground="#00FFFFFF" />
                        <Run x:Name="InlineSuggestionSuffixRun" Foreground="{StaticResource SuggestionGhostText}" />
                    </TextBlock>

                    <TextBox x:Name="NameTextBox"
                             Background="Transparent"
                             Foreground="{StaticResource TextPrimary}"
                             CaretBrush="{StaticResource TextPrimary}"
                             FontFamily="Segoe UI Variable Text, Segoe UI"
                             FontSize="13"
                             BorderThickness="0"
                             Margin="0"
                             Padding="8,5,8,6"
                             VerticalContentAlignment="Center"
                             TextOptions.TextFormattingMode="Display"
                             PreviewKeyDown="NameTextBox_KeyDown"
                             TextChanged="NameTextBox_TextChanged"
                             SelectionChanged="NameTextBox_SelectionChanged" />
                </Grid>
            </Border>

            <Popup x:Name="SuggestionsPopup"
                   Placement="Bottom"
                   PlacementTarget="{Binding ElementName=NameInputBorder}"
                   VerticalOffset="8"
                   AllowsTransparency="True"
                   PopupAnimation="Fade"
                   StaysOpen="False">
                <Border Width="{Binding ElementName=NameInputBorder, Path=ActualWidth}"
                        Background="{StaticResource SuggestionPopupBg}"
                        BorderBrush="{StaticResource SuggestionPopupBorder}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="8"
                        Effect="{StaticResource WinShadow}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <DockPanel Grid.Row="0" Margin="2,0,2,8" LastChildFill="False">
                            <TextBlock FontFamily="Segoe UI Variable Display, Segoe UI"
                                       FontSize="11"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimary}"
                                       Text="Suggestions" />
                            <TextBlock Margin="8,0,0,0"
                                       FontFamily="Segoe UI Variable Display, Segoe UI"
                                       FontSize="11"
                                       Foreground="{StaticResource TextSecondary}"
                                       Text="Game lists • offline" />
                        </DockPanel>

                        <ListBox x:Name="SuggestionsListBox"
                                 Grid.Row="1"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                                 MaxHeight="220"
                                 ItemContainerStyle="{StaticResource SuggestionListItemStyle}"
                                 SelectionChanged="SuggestionsListBox_SelectionChanged"
                                 PreviewMouseLeftButtonUp="SuggestionsListBox_PreviewMouseLeftButtonUp">
                            <ListBox.Resources>
                                <SolidColorBrush x:Key="SuggestionScrollTrackBrush" Color="#2B2B2B" />
                                <SolidColorBrush x:Key="SuggestionScrollThumbBrush" Color="#5A5A5A" />
                                <SolidColorBrush x:Key="SuggestionScrollThumbHoverBrush" Color="#75CFF9" />
                                <SolidColorBrush x:Key="SuggestionScrollThumbDraggingBrush" Color="#95DCFF" />

                                <Style x:Key="SuggestionScrollPageButtonStyle" TargetType="RepeatButton">
                                    <Setter Property="Focusable" Value="False" />
                                    <Setter Property="IsTabStop" Value="False" />
                                    <Setter Property="Background" Value="Transparent" />
                                    <Setter Property="BorderThickness" Value="0" />
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Rectangle Fill="Transparent" />
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>

                                <Style TargetType="Thumb">
                                    <Setter Property="Focusable" Value="False" />
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border x:Name="ThumbRoot"
                                                        Margin="1"
                                                        Background="{StaticResource SuggestionScrollThumbBrush}"
                                                        CornerRadius="3" />
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="ThumbRoot" Property="Background" Value="{StaticResource SuggestionScrollThumbHoverBrush}" />
                                                    </Trigger>
                                                    <Trigger Property="IsDragging" Value="True">
                                                        <Setter TargetName="ThumbRoot" Property="Background" Value="{StaticResource SuggestionScrollThumbDraggingBrush}" />
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>

                                <Style TargetType="ScrollBar">
                                    <Setter Property="Width" Value="10" />
                                    <Setter Property="Margin" Value="6,0,0,0" />
                                    <Setter Property="Background" Value="Transparent" />
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ScrollBar">
                                                <Grid Width="{TemplateBinding Width}" Background="Transparent">
                                                    <Border Margin="2,0"
                                                            Background="{StaticResource SuggestionScrollTrackBrush}"
                                                            CornerRadius="3" />
                                                    <Track x:Name="PART_Track"
                                                           IsDirectionReversed="True"
                                                           Focusable="False">
                                                        <Track.DecreaseRepeatButton>
                                                            <RepeatButton Style="{StaticResource SuggestionScrollPageButtonStyle}"
                                                                          Command="ScrollBar.PageUpCommand" />
                                                        </Track.DecreaseRepeatButton>
                                                        <Track.Thumb>
                                                            <Thumb MinHeight="28" />
                                                        </Track.Thumb>
                                                        <Track.IncreaseRepeatButton>
                                                            <RepeatButton Style="{StaticResource SuggestionScrollPageButtonStyle}"
                                                                          Command="ScrollBar.PageDownCommand" />
                                                        </Track.IncreaseRepeatButton>
                                                    </Track>
                                                </Grid>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="Orientation" Value="Horizontal">
                                                        <Setter Property="Height" Value="10" />
                                                        <Setter Property="Width" Value="Auto" />
                                                        <Setter Property="Margin" Value="0,6,0,0" />
                                                        <Setter TargetName="PART_Track" Property="IsDirectionReversed" Value="False" />
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ListBox.Resources>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel>
                                        <TextBlock Text="{Binding Title}"
                                                   Foreground="{StaticResource TextPrimary}"
                                                   FontFamily="Segoe UI Variable Display, Segoe UI"
                                                   FontSize="12.5"
                                                   TextTrimming="CharacterEllipsis" />
                                        <TextBlock Margin="0,3,0,0"
                                                   Text="{Binding Details}"
                                                   Foreground="{StaticResource TextSecondary}"
                                                   FontFamily="Segoe UI Variable Display, Segoe UI"
                                                   FontSize="11"
                                                   TextTrimming="CharacterEllipsis" />
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                </Border>
            </Popup>

            <Grid Grid.Row="3" Margin="0,10,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock x:Name="SuggestionStatusText"
                           Grid.Column="0"
                           FontFamily="Segoe UI Variable Display, Segoe UI"
                           FontSize="11"
                           Foreground="{StaticResource TextSecondary}"
                           Text="Suggestions from game lists." />

                <TextBlock Grid.Column="1"
                           Margin="12,0,0,0"
                           FontFamily="Segoe UI Variable Display, Segoe UI"
                           FontSize="11"
                           Foreground="{StaticResource AccentColor}"
                           Text="Tab to autocomplete" />
            </Grid>

            <StackPanel Grid.Row="4" Margin="0,14,0,0"
                        Orientation="Horizontal"
                        HorizontalAlignment="Center">
                <Button Content="Cancel" Width="80"
                        Style="{StaticResource ActionBtn}"
                        Click="Cancel_Click" />
                <Button Content="Rename" Width="90" Margin="8,0,0,0"
                        Style="{StaticResource AccentBtn}"
                        Click="Rename_Click" />
            </StackPanel>
        </Grid>
    </Border>
</Window>


