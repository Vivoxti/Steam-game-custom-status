<Window x:Class="SteamGameCustomStatus.UI.Windows.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Steam Game Custom Status"
        Width="380"
        Height="400"
        MinWidth="380"
        MinHeight="400"
        Background="Transparent"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <SolidColorBrush x:Key="WindowBg" Color="#1E1E1E" />
        <SolidColorBrush x:Key="BorderStroke" Color="#333333" />
        <SolidColorBrush x:Key="TextPrimary" Color="#FFFFFF" />
        <SolidColorBrush x:Key="TextSecondary" Color="#999999" />
        <SolidColorBrush x:Key="BtnBg" Color="#2D2D2D" />
        <SolidColorBrush x:Key="BtnHover" Color="#383838" />
        <SolidColorBrush x:Key="BtnPressed" Color="#252525" />
        <SolidColorBrush x:Key="AccentColor" Color="#60CDFF" />
        <SolidColorBrush x:Key="AccentHover" Color="#78D6FF" />
        <SolidColorBrush x:Key="AccentPressed" Color="#4AB8E8" />
        <SolidColorBrush x:Key="SuccessBg" Color="#13261C" />
        <SolidColorBrush x:Key="SuccessBorder" Color="#245135" />
        <SolidColorBrush x:Key="SuccessText" Color="#89F0AE" />
        <SolidColorBrush x:Key="WarningBg" Color="#2A2114" />
        <SolidColorBrush x:Key="WarningBorder" Color="#5C4420" />
        <SolidColorBrush x:Key="WarningText" Color="#FFD38A" />

        <DropShadowEffect x:Key="WinShadow" BlurRadius="24" ShadowDepth="0" Opacity="0.3" Color="#000000" />

        <Style x:Key="ActionBtn" TargetType="Button">
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
            <Setter Property="Background" Value="{StaticResource BtnBg}" />
            <Setter Property="FontFamily" Value="Segoe UI Variable Display, Segoe UI" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Height" Value="36" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{StaticResource BorderStroke}"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="16,0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource BtnHover}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource BtnPressed}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="AccentBtn" TargetType="Button" BasedOn="{StaticResource ActionBtn}">
            <Setter Property="Background" Value="{StaticResource AccentColor}" />
            <Setter Property="Foreground" Value="#000000" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="16,0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource AccentHover}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource AccentPressed}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CloseBtn" TargetType="Button">
            <Setter Property="Width" Value="36" />
            <Setter Property="Height" Value="28" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{StaticResource TextSecondary}" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="4">
                            <TextBlock Text="✕" HorizontalAlignment="Center" VerticalAlignment="Center"
                                       Foreground="{TemplateBinding Foreground}" FontSize="11" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#C42B1C" />
                                <Setter Property="Foreground" Value="White" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Margin="12"
            Background="{StaticResource WindowBg}"
            BorderBrush="{StaticResource BorderStroke}"
            BorderThickness="1"
            CornerRadius="8"
            Effect="{StaticResource WinShadow}">
        <Grid>
            <!-- Title bar -->
            <DockPanel Height="40" VerticalAlignment="Top"
                       MouseLeftButtonDown="TitleBar_OnMouseLeftButtonDown">
                <Button DockPanel.Dock="Right" Margin="0,6,8,0" VerticalAlignment="Top"
                        Style="{StaticResource CloseBtn}" Click="Hide_Click" />
                <TextBlock Margin="16,0,0,0" VerticalAlignment="Center"
                           FontFamily="Segoe UI Variable Display, Segoe UI"
                           FontSize="12" Foreground="{StaticResource TextSecondary}"
                           Text="Steam Game Custom Status" />
            </DockPanel>

            <!-- Content -->
            <StackPanel Margin="28,52,28,14" VerticalAlignment="Top">
                <TextBlock FontFamily="Segoe UI Variable Display, Segoe UI"
                           FontSize="22" FontWeight="SemiBold"
                           Foreground="{StaticResource TextPrimary}"
                           Text="Custom Status" />
                <TextBlock Margin="0,6,0,0"
                           FontFamily="Segoe UI Variable Display, Segoe UI"
                           FontSize="13" Foreground="{StaticResource TextSecondary}"
                           TextWrapping="Wrap"
                           Text="Manage the non-Steam game name and launch it through Steam." />

                <Border x:Name="RegisteredStatusCard"
                        Margin="0,16,0,0"
                        Padding="14,12"
                        Background="{StaticResource SuccessBg}"
                        BorderBrush="{StaticResource SuccessBorder}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Visibility="Collapsed">
                    <StackPanel>
                        <TextBlock FontFamily="Segoe UI Variable Display, Segoe UI"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource SuccessText}"
                                   Text="Added to Steam as a non-Steam game" />
                        <TextBlock x:Name="RegisteredStatusDescription"
                                   Margin="0,6,0,0"
                                   FontFamily="Segoe UI Variable Display, Segoe UI"
                                   FontSize="12"
                                   Foreground="{StaticResource TextPrimary}"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <Border x:Name="MissingStatusCard"
                        Margin="0,16,0,0"
                        Padding="14,12"
                        Background="{StaticResource WarningBg}"
                        BorderBrush="{StaticResource WarningBorder}"
                        BorderThickness="1"
                        CornerRadius="8"
                        ToolTipService.ShowDuration="60000"
                        Visibility="Collapsed">
                    <StackPanel>
                        <TextBlock FontFamily="Segoe UI Variable Display, Segoe UI"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource WarningText}"
                                   Text="Not found in Steam as a non-Steam game" />
                        <TextBlock x:Name="MissingStatusDescription"
                                   Margin="0,6,0,0"
                                   FontFamily="Segoe UI Variable Display, Segoe UI"
                                   FontSize="12"
                                   Foreground="{StaticResource TextPrimary}"
                                   TextWrapping="Wrap" />
                        <TextBlock x:Name="MissingStatusHint"
                                   Margin="0,8,0,0"
                                   FontFamily="Segoe UI Variable Display, Segoe UI"
                                   FontSize="12"
                                   Foreground="{StaticResource TextSecondary}"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <StackPanel x:Name="RegisteredActionsPanel"
                            Margin="0,18,0,0"
                            Visibility="Collapsed">
                    <Button Content="Rename"
                            Style="{StaticResource AccentBtn}"
                            Click="RenameButton_Click" />
                    <Button Margin="0,8,0,0"
                            Content="Create Desktop Shortcut"
                            Style="{StaticResource ActionBtn}"
                            Click="CreateDesktopShortcut_Click" />
                </StackPanel>

                <StackPanel x:Name="MissingActionsPanel"
                            Margin="0,18,0,0"
                            Visibility="Collapsed">
                    <Button x:Name="OpenSteamAddGameButton"
                            Content="Open Steam to Add Game"
                            Style="{StaticResource AccentBtn}"
                            Click="OpenSteamAddGame_Click" />
                </StackPanel>

                <Border x:Name="InlineMessageCard"
                        Margin="0,10,0,0"
                        Padding="12,8"
                        Background="{StaticResource SuccessBg}"
                        BorderBrush="{StaticResource SuccessBorder}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Opacity="0"
                        Visibility="Collapsed">
                    <TextBlock x:Name="InlineMessageText"
                               FontFamily="Segoe UI Variable Display, Segoe UI"
                               FontSize="12"
                               Foreground="{StaticResource SuccessText}"
                               TextWrapping="Wrap" />
                </Border>
            </StackPanel>
        </Grid>
    </Border>
</Window>
