<Window x:Class="SteamGameCustomStatus.RenameDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Rename"
        Width="380"
        Height="210"
        MinHeight="210"
        Background="Transparent"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        WindowStartupLocation="Manual">
    <Window.Resources>
        <SolidColorBrush x:Key="WindowBg" Color="#1E1E1E" />
        <SolidColorBrush x:Key="BorderStroke" Color="#333333" />
        <SolidColorBrush x:Key="TextPrimary" Color="#FFFFFF" />
        <SolidColorBrush x:Key="TextSecondary" Color="#999999" />
        <SolidColorBrush x:Key="BtnBg" Color="#2D2D2D" />
        <SolidColorBrush x:Key="BtnHover" Color="#383838" />
        <SolidColorBrush x:Key="BtnPressed" Color="#252525" />
        <SolidColorBrush x:Key="AccentColor" Color="#60CDFF" />
        <SolidColorBrush x:Key="AccentHover" Color="#78D6FF" />
        <SolidColorBrush x:Key="AccentPressed" Color="#4AB8E8" />
        <SolidColorBrush x:Key="InputBg" Color="#2D2D2D" />
        <SolidColorBrush x:Key="InputBgHover" Color="#333333" />
        <SolidColorBrush x:Key="InputBorder" Color="#444444" />
        <SolidColorBrush x:Key="InputBorderHover" Color="#565656" />
        <SolidColorBrush x:Key="InputBorderFocus" Color="#60CDFF" />

        <DropShadowEffect x:Key="WinShadow" BlurRadius="24" ShadowDepth="0" Opacity="0.3" Color="#000000" />

        <Style x:Key="ActionBtn" TargetType="Button">
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
            <Setter Property="Background" Value="{StaticResource BtnBg}" />
            <Setter Property="FontFamily" Value="Segoe UI Variable Display, Segoe UI" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Height" Value="34" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{StaticResource BorderStroke}"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="16,0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource BtnHover}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource BtnPressed}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="AccentBtn" TargetType="Button" BasedOn="{StaticResource ActionBtn}">
            <Setter Property="Background" Value="{StaticResource AccentColor}" />
            <Setter Property="Foreground" Value="#000000" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="16,0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource AccentHover}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource AccentPressed}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="InputChrome" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource InputBg}" />
            <Setter Property="BorderBrush" Value="{StaticResource InputBorder}" />
            <Setter Property="BorderThickness" Value="1" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource InputBgHover}" />
                    <Setter Property="BorderBrush" Value="{StaticResource InputBorderHover}" />
                </Trigger>
                <Trigger Property="IsKeyboardFocusWithin" Value="True">
                    <Setter Property="Background" Value="{StaticResource InputBg}" />
                    <Setter Property="BorderBrush" Value="{StaticResource InputBorderFocus}" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Border Margin="12"
            Background="{StaticResource WindowBg}"
            BorderBrush="{StaticResource BorderStroke}"
            BorderThickness="1"
            CornerRadius="8"
            Effect="{StaticResource WinShadow}"
            MouseLeftButtonDown="TitleBar_OnMouseLeftButtonDown">
        <Grid Margin="20,16,20,18">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0"
                       FontFamily="Segoe UI Variable Display, Segoe UI"
                       FontSize="15" FontWeight="SemiBold"
                       Foreground="{StaticResource TextPrimary}"
                       Text="Rename non-Steam game" />

            <TextBlock Grid.Row="1" Margin="0,6,0,0"
                       FontFamily="Segoe UI Variable Display, Segoe UI"
                       FontSize="12"
                       Foreground="{StaticResource TextSecondary}"
                       Text="Enter a new display name for Steam." />

            <Border Grid.Row="2" Margin="0,12,0,0"
                    Style="{StaticResource InputChrome}"
                    CornerRadius="6"
                    Height="40"
                    Padding="2,0"
                    VerticalAlignment="Top">
                <TextBox x:Name="NameTextBox"
                         Background="Transparent"
                         Foreground="{StaticResource TextPrimary}"
                         CaretBrush="{StaticResource TextPrimary}"
                         FontFamily="Segoe UI Variable Text, Segoe UI"
                         FontSize="13"
                         BorderThickness="0"
                         Margin="0"
                         Padding="8,5,8,6"
                         VerticalContentAlignment="Center"
                         TextOptions.TextFormattingMode="Display"
                         KeyDown="NameTextBox_KeyDown" />
            </Border>

            <StackPanel Grid.Row="3" Margin="0,14,0,0"
                        Orientation="Horizontal"
                        HorizontalAlignment="Center">
                <Button Content="Cancel" Width="80"
                        Style="{StaticResource ActionBtn}"
                        Click="Cancel_Click" />
                <Button Content="Rename" Width="90" Margin="8,0,0,0"
                        Style="{StaticResource AccentBtn}"
                        Click="Rename_Click" />
            </StackPanel>
        </Grid>
    </Border>
</Window>


